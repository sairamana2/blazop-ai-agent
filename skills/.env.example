# ─── REQUIRED (already working) ─────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
GROQ_API_KEY=gsk_your-groq-key-here

# ─── NEW: Email Integration (optional - mock works without these) ─────────────
# Set these for real email sending via SMTP (e.g. Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email address that receives support ticket notifications
SUPPORT_EMAIL=support@blazop.com

# ─── NEW: Email → Slack Polling (optional) ────────────────────────────────────
# Set to true to enable mock email polling every 60 seconds
EMAIL_POLLING_ENABLED=false

# Channel ID where email notifications are posted (e.g. C0B97CB84AU)
SLACK_DEFAULT_CHANNEL=your-channel-id-here
